{
  "name": "commerceos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.8.0",
  "scripts": {
    "dev": "turbo dev --filter=@commerceos/app-shell",
    "build": "turbo build",
