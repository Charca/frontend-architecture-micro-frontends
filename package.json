{
  "name": "commerceos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.8.0",
  "scripts": {
    "dev": "turbo dev --filter=@commerceos/api --filter=@commerceos/app-shell --filter=@commerceos/analytics",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "preview": "turbo preview --filter=@commerceos/api --filter=@commerceos/app-shell --filter=@commerceos/analytics",
    "boundaries": "turbo boundaries"
  },
  "devDependencies": {
    "@module-federation/rsbuild-plugin": "^2.4.0",
    "turbo": "^2.9.12"
  },
  "dependencies": {
    "@module-federation/runtime-tools": "^2.4.0"
  }
}