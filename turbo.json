{
    "$schema": "https://turborepo.dev/schema.json",
    "concurrency": "20",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "dev": {
            "persistent": true,
            "cache": false
        },
        "lint": {},
        "typecheck": {},
        "preview": {}
    }
}